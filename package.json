{
  "name": "atlas-os",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@9.15.0",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "pnpm -r build",
    "test": "pnpm -r test",
    "lint": "eslint .",
    "format": "prettier --write .",
    "typecheck": "tsc -p tsconfig.json && pnpm -r typecheck",
    "db:migrate": "pnpm --filter @atlas/db migrate",
    "db:seed": "tsx scripts/db-seed.ts",
    "tenant:create": "tsx scripts/tenant-create.ts",
    "content:validate": "tsx scripts/content-validate.ts",
    "content:score": "tsx scripts/content-score.ts",
    "decisions:log": "tsx scripts/decisions-log.ts",
    "queue:enqueue": "tsx scripts/queue-enqueue.ts",
    "events:add": "tsx scripts/events-add.ts",
    "ingest:run": "pnpm --filter @atlas/ingest run",
    "policy:check": "tsx policy/src/cli.ts"
  },
  "dependencies": {
    "@atlas/core": "workspace:*",
    "@atlas/db": "workspace:*",
    "@atlas/llm": "workspace:*",
    "yaml": "^2.5.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "@typescript-eslint/eslint-plugin": "^7.18.0",
    "@typescript-eslint/parser": "^7.18.0",
    "eslint": "^8.57.0",
    "eslint-config-prettier": "^9.1.0",
    "prettier": "^3.3.3",
    "tsx": "^4.19.0",
    "typescript": "^5.5.4",
    "vitest": "^2.1.8"
  }
}
