---
// Base document shell. Semantic HTML, correct heading hierarchy, no layout
// shift: fonts are system-stack (no webfont swap), and nothing above the fold
// loads asynchronously (plan §3.2, Lighthouse 95+ mobile).
import { DEFAULT_TENANT_DOMAIN } from '@atlas/core';

interface Props {
  title: string;
  description?: string;
  /** Absolute canonical URL. */
  canonical?: string;
  /** JSON-LD blocks to emit in the head. */
  schemas?: Record<string, unknown>[];
  noindex?: boolean;
}

const { title, description, canonical, schemas = [], noindex = false } = Astro.props;

// TODO(setup): replace with the real brand name once the niche is chosen.
// See OPEN-QUESTIONS.md §1.
const SITE_NAME = 'PLACEHOLDER_NICHE Guide';
const href = canonical ?? new URL(Astro.url.pathname, Astro.site ?? `https://${DEFAULT_TENANT_DOMAIN}`).toString();
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    {description && <meta name="description" content={description} />}
    <link rel="canonical" href={href} />
    {noindex && <meta name="robots" content="noindex, nofollow" />}
    <meta property="og:title" content={title} />
    {description && <meta property="og:description" content={description} />}
    <meta property="og:type" content="article" />
    <meta property="og:url" content={href} />
    <meta name="generator" content={Astro.generator} />

    {
      schemas.map((schema) => (
        <script type="application/ld+json" set:html={JSON.stringify(schema)} is:inline />
      ))
    }

    {/* TODO(setup): PostHog snippet goes here once POSTHOG_PROJECT_API_KEY is
        set. Install it during Stage 1 so collection starts immediately — the
        recordings are only useful if they exist (plan §4.2). */}
  </head>

  <body>
    <a class="skip-link" href="#main">Skip to content</a>

    <header class="site-header">
      <nav aria-label="Primary">
        <a class="brand" href="/">{SITE_NAME}</a>
      </nav>
    </header>

    <main id="main">
      <slot />
    </main>

    <footer class="site-footer">
      <p>
        &copy; {new Date().getFullYear()} {SITE_NAME}. Content is produced with AI
        assistance and reviewed before publication.
      </p>
    </footer>

    <style is:global>
      :root {
        --measure: 68ch;
        --gap: 1.25rem;
        color-scheme: light dark;
      }

      *,
      *::before,
      *::after {
        box-sizing: border-box;
      }

      body {
        margin: 0;
        font-family:
          system-ui,
          -apple-system,
          'Segoe UI',
          Roboto,
          sans-serif;
        line-height: 1.65;
        font-size: 1.0625rem;
      }

      main {
        max-width: var(--measure);
        margin: 0 auto;
        padding: 0 var(--gap) 4rem;
      }

      h1,
      h2,
      h3 {
        line-height: 1.25;
        text-wrap: balance;
      }

      h1 {
        font-size: 2rem;
        margin-top: 0;
      }

      img,
      video {
        max-width: 100%;
        height: auto;
      }

      a {
        color: inherit;
      }

      .skip-link {
        position: absolute;
        left: -9999px;
      }

      .skip-link:focus {
        left: 0.5rem;
        top: 0.5rem;
        padding: 0.5rem;
        background: Canvas;
        z-index: 10;
      }

      .site-header,
      .site-footer {
        max-width: var(--measure);
        margin: 0 auto;
        padding: 1rem var(--gap);
        font-size: 0.9375rem;
      }

      .brand {
        font-weight: 600;
        text-decoration: none;
      }

      .site-footer {
        margin-top: 3rem;
        border-top: 1px solid currentColor;
        opacity: 0.8;
      }

      table {
        width: 100%;
        border-collapse: collapse;
        margin: 1.5rem 0;
        font-size: 0.9375rem;
      }

      th,
      td {
        border: 1px solid currentColor;
        padding: 0.5rem 0.75rem;
        text-align: left;
      }
    </style>
  </body>
</html>
