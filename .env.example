# ============================================================================
# Atlas OS — environment variables
# Copy to .env and fill in. Every variable used anywhere in the repo is
# documented here. No secrets are ever committed; code reads process.env and
# fails loudly (naming the variable) when a required value is missing.
# ============================================================================

# ---------------------------------------------------------------------------
# Database (Supabase Postgres)
# TODO(setup): create a Supabase project (https://supabase.com/dashboard),
# then copy the "Connection string" (URI, session mode) from
# Project Settings → Database. Include the password.
# ---------------------------------------------------------------------------
DATABASE_URL=postgresql://postgres:PASSWORD@db.PROJECT_REF.supabase.co:5432/postgres

# ---------------------------------------------------------------------------
# Anthropic API (all LLM calls route through packages/llm)
# TODO(setup): create a key at https://console.anthropic.com/settings/keys
# ---------------------------------------------------------------------------
ANTHROPIC_API_KEY=

# Monthly LLM budget in USD. The router degrades to cheaper tiers as spend
# approaches this cap and hard-stops at 100%. See packages/llm/src/budget.ts
ATLAS_LLM_MONTHLY_BUDGET_USD=100

# ---------------------------------------------------------------------------
# GitHub (agents open proposals as PRs; Policy Engine runs in Actions)
# TODO(setup): create a fine-grained PAT with contents:write + pull_requests:write
# on this repo (https://github.com/settings/personal-access-tokens).
# In GitHub Actions the built-in GITHUB_TOKEN is used instead.
# ---------------------------------------------------------------------------
GITHUB_TOKEN=
# owner/repo the agents open PRs against
GITHUB_REPO=cadendane-droid/AutonomousCompany

# ---------------------------------------------------------------------------
# Google Search Console
# TODO(setup): 1) create a GCP project, enable "Search Console API",
# 2) create a service account + JSON key, 3) add the service account email as
# a user (Full permission) on the Search Console property.
# GSC_PRIVATE_KEY is the JSON key's private_key field, with literal \n escapes.
# ---------------------------------------------------------------------------
GSC_CLIENT_EMAIL=
GSC_PRIVATE_KEY=
# The verified property. Domain properties use the sc-domain: prefix.
# TODO(setup): replace with the real domain once chosen (placeholder: example-tenant.com)
GSC_SITE_URL=sc-domain:example-tenant.com

# ---------------------------------------------------------------------------
# PostHog
# TODO(setup): create a project at https://us.posthog.com. The *project* API
# key (phc_...) is public and goes in the site snippet; the *personal* API key
# (phx_...) is secret and is used by the ingest connector for HogQL queries.
# ---------------------------------------------------------------------------
POSTHOG_PROJECT_API_KEY=
POSTHOG_PERSONAL_API_KEY=
POSTHOG_PROJECT_ID=
POSTHOG_HOST=https://us.posthog.com

# ---------------------------------------------------------------------------
# Vercel (Speed Insights ingest + rollback automation)
# TODO(setup): create a token at https://vercel.com/account/tokens after the
# site project exists. VERCEL_TEAM_ID may be empty on a personal account.
# ---------------------------------------------------------------------------
VERCEL_TOKEN=
VERCEL_PROJECT_ID=
VERCEL_TEAM_ID=

# ---------------------------------------------------------------------------
# Site
# TODO(setup): replace with the real production domain once chosen.
# Single source of truth for the deployed origin; the Astro config reads it.
# ---------------------------------------------------------------------------
SITE_BASE_URL=https://example-tenant.com
